<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:ns1="http://schemas.android.com/tools">
    <color name="splash_background">#F6F1E7</color>
    <string name="app_name">CIT Club Connect</string>
    <string name="notification_channel_description">New and updated club events across CIT.</string>
    <string name="notification_channel_name">CIT club event updates</string>
    <string name="notification_fallback_body">A new update is waiting in the app.</string>
    <string name="notification_fallback_title">CIT Club Connect</string>
    <style name="Theme.CITClubConnect" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" ns1:targetApi="o_mr1">true</item>
    </style>
    <style name="Theme.CITClubConnect.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/club_logo_placeholder</item>
        <item name="postSplashScreenTheme">@style/Theme.CITClubConnect</item>
    </style>
</resources>